      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB_F1"
          },
          "query": "from(bucket: \"f1_telemetry_raw\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"telemetry_fast\")\n  |> filter(fn: (r) => not (r[\"driver_name\"] =~ /^Piloto/))\n  |> filter(fn: (r) => r[\"_field\"] == \"speed\")\n  |> group(columns: [\"driver_name\"])\n  |> aggregateWindow(every: 500ms, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2
          },
          "unit": "velocity-kmh"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "max"
          ],
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
